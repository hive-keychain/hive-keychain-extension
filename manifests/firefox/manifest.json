{
  "name": "__MSG_keychain__",
  "description": "__MSG_description__",
  "default_locale": "en",
  "version": "3.12.5",
  "permissions": [
    "storage",
    "idle",
    "alarms",
    "notifications",
    "webNavigation"
  ],
  "content_security_policy": "script-src 'self'; object-src 'self';",
  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": "/assets/images/iconhive.png"
  },
  "icons": { "128": "/assets/images/iconhive.png" },
  "background": { "scripts": ["backgroundBundle.js"], "persistent": true },
  "web_accessible_resources": [
    "/images/logo.png",
    "hive_keychain.js",
    "evmKeychainBundle.js"
  ],
  "content_scripts": [
    {
      "matches": ["https://*/*", "http://0.0.0.0:1337/*", "http://*/*"],
      "js": [
        "web_interfaceBundle.js",
        "keychainifyBundle.js",
        "evmContentScriptBundle.js"
      ],
      "all_frames": true
    }
  ],
  "manifest_version": 2,
  "applications": {
    "gecko": { "id": "{b6bd7e35-0762-42a2-a283-95a94635047d}" }
  }
}
